<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Canaway — Asesoría Especial IELTS y CELPIP</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
<style>
  /* ─── TOKENS ───────────────────────────────────────── */
  :root {
    --red: #DB1709;
    --red-dark: #721515;
    --red-light: #ff5c4d;
    --red-pale: #fff0ee;
    --black: #1a1a1a;
    --white: #ffffff;
    --bg: #ffffff;
    --bg-alt: #f7f6f4;
    --bg-pale: #fff0ee;
    --border: #e8e5e2;
    --text: #2a2a2a;
    --text-soft: #6b6867;
    --radius: 14px;
    --shadow: 0 2px 16px rgba(0,0,0,0.06);
    --shadow-md: 0 6px 28px rgba(0,0,0,0.10);
    --transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); overflow-x: hidden; }

  /* ─── ANIMACIONES ──────────────────────────────────── */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeInScale {
    from { opacity: 0; transform: scale(0.92) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  @keyframes heroPop {
    0% { opacity: 0; transform: translateY(30px) scale(0.95); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }
  .animate-on-scroll {
    opacity: 0;
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .animate-on-scroll.visible { animation: fadeInUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards; }
  .animate-scale.visible { animation: fadeInScale 0.9s cubic-bezier(0.4, 0, 0.2, 1) forwards; }

  .hero-content > * { animation: heroPop 0.9s cubic-bezier(0.4, 0, 0.2, 1) backwards; }
  .hero-content .hero-eyebrow { animation-delay: 80ms; }
  .hero-content h1 { animation-delay: 200ms; }
  .hero-content > p { animation-delay: 380ms; }
  .hero-content ul { animation-delay: 560ms; }

  button {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  button:hover {
    transform: translateY(-2px);
  }

  /* ─── HERO — variante LIGHT (consistente con landing principal) ─ */
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #fff0ee 0%, #f7f6f4 100%);
    color: var(--text);
    padding: 120px 24px 100px;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0; z-index: 0;
    background-image: url('https://images.unsplash.com/photo-1517935706615-2717063c2225?auto=format&fit=crop&w=2400&q=80');
    background-size: cover;
    background-position: center 35%;
    opacity: 0.14;
    filter: saturate(0.9);
  }
  .hero::after {
    content: '';
    position: absolute; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 70% 50% at 50% -10%, rgba(219,23,9,0.10) 0%, transparent 65%),
      linear-gradient(180deg, rgba(255,240,238,0.55) 0%, rgba(247,246,244,0.85) 100%);
    pointer-events: none;
  }
  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    max-width: 1180px;
    margin: 0 auto;
  }
  @media (max-width: 960px) {
    .hero-grid { grid-template-columns: 1fr; gap: 48px; }
  }
  .hero-eyebrow {
    display: inline-block;
    font-family: 'Poppins', sans-serif;
    font-size: 0.73rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    background: var(--red);
    padding: 8px 20px;
    border-radius: 100px;
    margin-bottom: 28px;
    box-shadow: 0 2px 8px rgba(219,23,9,0.3);
  }
  .hero-content h1 {
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: clamp(2.1rem, 4.6vw, 3.3rem);
    line-height: 1.13;
    letter-spacing: -0.025em;
    color: var(--black);
  }
  .hero-content h1 em {
    font-style: normal;
    color: var(--red);
  }
  .hero-content > p {
    margin-top: 20px;
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text-soft);
    max-width: 540px;
  }
  .hero-bullets {
    margin-top: 32px;
    list-style: none;
    font-size: 1rem;
    line-height: 1.7;
  }
  .hero-bullets li {
    display: flex;
    gap: 12px;
    margin-bottom: 14px;
    align-items: flex-start;
    color: var(--text);
  }
  .hero-bullets li::before {
    content: "✓";
    color: var(--red);
    font-weight: 700;
    font-size: 1.3rem;
    line-height: 1;
    margin-top: 2px;
    flex-shrink: 0;
  }

  /* ─── FORMULARIO ───────────────────────────────────── */
  .form-card {
    background: var(--white);
    color: var(--text);
    border-radius: 28px;
    padding: 32px;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border);
  }
  .form-eyebrow {
    display: inline-block;
    font-family: 'Poppins', sans-serif;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 10px;
  }
  .form-card h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.45rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--black);
    margin-bottom: 14px;
  }
  .form-card .form-desc {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--text-soft);
    margin-bottom: 20px;
  }
  .price-box {
    background: linear-gradient(135deg, var(--red-pale) 0%, #fde4e1 100%);
    border-radius: 16px;
    padding: 16px 18px;
    margin-bottom: 24px;
    border: 1px solid rgba(219,23,9,0.12);
  }
  .price-box .price-label {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--red-dark);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .price-box .price-amount {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--black);
    line-height: 1.1;
    margin-top: 4px;
  }
  .price-box .price-note {
    display: block;
    font-size: 0.78rem;
    color: var(--text-soft);
    margin-top: 8px;
    line-height: 1.5;
  }
  .form-card form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .form-card input,
  .form-card select {
    width: 100%;
    border: 1px solid #e5e5e4;
    border-radius: 14px;
    padding: 15px 18px;
    font-size: 0.95rem;
    font-family: 'Inter', sans-serif;
    color: var(--text);
    outline: none;
    background: var(--white);
    transition: border-color var(--transition), box-shadow 0.3s ease;
  }
  .form-card select { cursor: pointer; }
  .form-card input:focus,
  .form-card select:focus {
    border-color: var(--red);
    box-shadow: 0 0 0 4px rgba(219,23,9,0.12);
  }
  .form-submit {
    margin-top: 6px;
    width: 100%;
    background: var(--red);
    color: var(--white);
    border: none;
    border-radius: 14px;
    padding: 17px;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: background 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }
  .form-submit:hover {
    background: var(--red-dark);
    box-shadow: 0 12px 28px -8px rgba(219,23,9,0.5);
    transform: translateY(-2px);
  }
  .form-submit svg { transition: transform 0.3s ease; }
  .form-submit:hover svg { transform: translateX(4px); }
  .form-note {
    margin-top: 16px;
    font-size: 0.78rem;
    color: var(--text-soft);
    line-height: 1.55;
    text-align: center;
  }
  .privacy-note {
    display: flex;
    align-items: center;
    gap: 8px;
    justify-content: center;
    margin-top: 12px;
    font-size: 0.76rem;
    color: var(--text-soft);
  }
  .privacy-note svg { color: var(--red); flex-shrink: 0; }

  /* ─── TÍTULOS / SECCIONES ──────────────────────────── */
  section { padding: 96px 24px; }
  .container { max-width: 1180px; margin: 0 auto; }
  .section-eyebrow {
    display: inline-block;
    font-family: 'Poppins', sans-serif;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 14px;
  }
  .section-eyebrow.on-dark { color: var(--red-light); }
  .section-title {
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: clamp(1.7rem, 3.4vw, 2.4rem);
    line-height: 1.18;
    letter-spacing: -0.022em;
    color: var(--black);
  }
  .section-title.on-dark { color: var(--white); }
  .section-lead {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text-soft);
    max-width: 660px;
    margin-top: 14px;
  }
  .section-lead.on-dark { color: rgba(255,255,255,0.78); }

  /* ─── TRUST BAND ───────────────────────────────────── */
  .trust-band {
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
    padding: 36px 24px;
  }
  .trust-grid {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }
  .trust-item {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--text);
    box-shadow: 0 2px 6px rgba(0,0,0,0.03);
    transition: all 0.3s ease;
  }
  .trust-item:hover {
    transform: translateY(-3px);
    border-color: var(--red);
    box-shadow: 0 12px 24px -8px rgba(219,23,9,0.15);
  }
  .trust-check {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--red-pale);
    color: var(--red);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .trust-check svg { width: 13px; height: 13px; }

  /* ─── PROGRAM FIT — para ti si... ──────────────────── */
  .fit-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 16px;
    margin-top: 44px;
  }
  .fit-card {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: 20px;
    padding: 22px 24px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .fit-card:hover {
    transform: translateY(-4px);
    border-color: var(--red);
    box-shadow: 0 16px 36px -12px rgba(219,23,9,0.18);
  }
  .fit-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--red);
    margin-top: 8px;
    flex-shrink: 0;
    box-shadow: 0 0 0 4px var(--red-pale);
  }
  .fit-card p {
    font-size: 0.96rem;
    line-height: 1.65;
    color: var(--text);
  }

  /* ─── TESTIMONIOS — fondo rojo pálido (consistente con landing principal) ── */
  .testimonials-section {
    background: var(--bg-pale);
    color: var(--text);
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 22px;
    margin-top: 44px;
  }
  .testimonial-card {
    position: relative;
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 30px 28px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .testimonial-card:hover {
    transform: translateY(-6px);
    border-color: var(--red);
    box-shadow: 0 20px 50px -12px rgba(219,23,9,0.18);
  }
  .testimonial-quote-mark {
    position: absolute;
    top: 6px;
    right: 22px;
    font-family: 'Poppins', sans-serif;
    font-size: 6.5rem;
    line-height: 1;
    font-weight: 900;
    color: var(--red);
    opacity: 0.09;
    pointer-events: none;
    user-select: none;
  }
  .testimonial-stars {
    display: inline-flex;
    gap: 3px;
    color: #f5b400;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
  }
  .testimonial-stars svg { width: 16px; height: 16px; }
  .testimonial-card p {
    position: relative;
    z-index: 1;
    color: var(--text);
    font-size: 0.96rem;
    line-height: 1.7;
  }
  .testimonial-banner {
    margin-top: 36px;
    border-radius: 22px;
    border: 1.5px solid rgba(219,23,9,0.25);
    background: var(--white);
    padding: 24px 32px;
    text-align: center;
    color: var(--red-dark);
    font-size: 1rem;
    line-height: 1.6;
    font-weight: 500;
  }

  /* ─── VALUE PROP ───────────────────────────────────── */
  .value-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 56px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .value-grid { grid-template-columns: 1fr; gap: 32px; }
  }
  .value-content p {
    font-size: 1.05rem;
    line-height: 1.78;
    color: var(--text);
    margin-bottom: 18px;
  }
  .value-content p:last-child { margin-bottom: 0; }

  /* ─── INCLUDES — qué recibirás (con iconos) ────────── */
  .includes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 22px;
    margin-top: 44px;
  }
  .include-card {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 30px 26px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .include-card:hover {
    transform: translateY(-6px);
    border-color: var(--red);
    box-shadow: 0 20px 40px -12px rgba(219,23,9,0.18);
  }
  .include-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: var(--red-pale);
    color: var(--red);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .include-icon svg { width: 28px; height: 28px; }
  .include-card:hover .include-icon {
    background: var(--red);
    color: var(--white);
    transform: scale(1.06) rotate(-4deg);
  }
  .include-card h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.18rem;
    font-weight: 600;
    color: var(--black);
    margin-bottom: 12px;
    line-height: 1.3;
  }
  .include-card p {
    font-size: 0.93rem;
    line-height: 1.7;
    color: var(--text-soft);
  }

  /* ─── AUTHORITY + VIDEO ────────────────────────────── */
  .authority-section {
    padding: 96px 24px;
  }
  .authority-wrap {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 36px;
    background: linear-gradient(135deg, var(--red-pale) 0%, #f7f6f4 100%);
    border-radius: 32px;
    padding: 56px;
  }
  @media (max-width: 900px) {
    .authority-wrap { grid-template-columns: 1fr; padding: 36px 28px; gap: 28px; }
  }
  .authority-content p {
    font-size: 1.02rem;
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 16px;
  }
  .authority-btn {
    margin-top: 12px;
    background: var(--black);
    color: var(--white);
    border: none;
    border-radius: 100px;
    padding: 16px 30px;
    font-weight: 600;
    font-size: 0.98rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s ease;
  }
  .authority-btn:hover {
    background: #000;
    box-shadow: 0 14px 28px -8px rgba(0,0,0,0.3);
  }
  .authority-btn svg { transition: transform 0.3s ease; }
  .authority-btn:hover svg { transform: translateX(4px); }
  .video-placeholder {
    background: var(--white);
    border-radius: 24px;
    border: 1px solid var(--border);
    padding: 40px 30px;
    min-height: 320px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    box-shadow: 0 8px 24px rgba(0,0,0,0.04);
    transition: all 0.4s ease;
    cursor: pointer;
  }
  .video-placeholder:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
  }
  .video-play {
    width: 78px;
    height: 78px;
    border-radius: 50%;
    background: var(--black);
    color: var(--white);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
    box-shadow: 0 14px 30px -8px rgba(0,0,0,0.4);
    transition: all 0.4s ease;
  }
  .video-placeholder:hover .video-play {
    background: var(--red);
    transform: scale(1.06);
  }
  .video-play svg {
    width: 28px;
    height: 28px;
    margin-left: 4px;
  }
  .video-placeholder h4 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.18rem;
    font-weight: 600;
    color: var(--black);
    margin-bottom: 6px;
  }
  .video-placeholder p {
    font-size: 0.9rem;
    color: var(--text-soft);
    line-height: 1.5;
  }

  /* ─── FAQ — fondo claro ────────────────────────────── */
  .faq-section {
    background: var(--bg-alt);
    color: var(--text);
  }
  .faq-section .container {
    max-width: 860px;
    text-align: center;
  }
  .faq-list {
    margin-top: 44px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-align: left;
  }
  .faq-item {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
    transition: all 0.3s ease;
  }
  .faq-item[open] {
    border-color: var(--red);
    box-shadow: 0 12px 28px -10px rgba(219,23,9,0.18);
  }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: 22px 26px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 1.02rem;
    color: var(--black);
    line-height: 1.4;
    transition: color 0.3s ease;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary:hover { color: var(--red); }
  .faq-toggle {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--red-pale);
    color: var(--red);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    line-height: 1;
    font-weight: 400;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .faq-item[open] .faq-toggle {
    transform: rotate(45deg);
    background: var(--red);
    color: var(--white);
  }
  .faq-item .faq-answer {
    padding: 0 26px 24px;
    color: var(--text-soft);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  /* ─── FINAL CTA — negro consistente con landing principal ─ */
  .final-cta-section {
    padding: 60px 24px 96px;
  }
  .final-cta {
    max-width: 1180px;
    margin: 0 auto;
    background: var(--black);
    color: var(--white);
    border-radius: 32px;
    padding: 64px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 60px -20px rgba(0,0,0,0.3);
  }
  .final-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 50% 100%, rgba(219,23,9,0.18) 0%, transparent 55%);
    pointer-events: none;
  }
  .final-cta > * { position: relative; z-index: 1; }
  .final-cta h2 {
    font-family: 'Poppins', sans-serif;
